<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taskforge.ui.controller.FileHubController"
            style="-fx-background-color: #F8FAFC;">

    <!-- ==================== HEADER ==================== -->
    <top>
        <VBox style="-fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 8, 0, 0, 3);">

            <!-- Top bar -->
            <HBox alignment="CENTER_LEFT" spacing="14"
                  style="-fx-background-color: #0F172A; -fx-padding: 12 24 12 20;">
                <Button text="← Kanban" onAction="#handleBack"
                        style="-fx-background-color: transparent; -fx-text-fill: #94A3B8;
                               -fx-font-size: 12px; -fx-cursor: hand;
                               -fx-border-color: #334155; -fx-border-radius: 6;
                               -fx-background-radius: 6; -fx-padding: 5 12 5 12;"/>
                <VBox spacing="1">
                    <Label fx:id="projectTitleLabel"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="File Hub"
                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusLabel"
                       style="-fx-text-fill: #FCA5A5; -fx-font-size: 12px;"/>
            </HBox>

            <!-- Toolbar: task selector + action buttons -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 12 24 12 24;
                         -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
                <Label text="Task"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <ComboBox fx:id="taskSelector" onAction="#handleTaskSelected"
                          prefWidth="300"
                          style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0;
                                 -fx-border-radius: 8; -fx-background-radius: 8;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="uploadButton" text="Upload File" onAction="#handleUpload"
                        style="-fx-background-color: #4F46E5; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 8 16 8 16; -fx-cursor: hand;"/>
                <Button fx:id="addLinkButton" text="Tambah Link" onAction="#handleAddLink"
                        style="-fx-background-color: white; -fx-text-fill: #475569;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 8 16 8 16; -fx-cursor: hand;
                               -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ==================== FILE LIST ==================== -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox fx:id="fileListPane" spacing="10"
                  style="-fx-padding: 20 28 28 28;"/>
        </ScrollPane>
    </center>
</BorderPane>
