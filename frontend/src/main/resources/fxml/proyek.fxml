<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taskforge.ui.controller.ProyekController"
            style="-fx-background-color: #F8FAFC;">

    <!-- ==================== SIDEBAR ==================== -->
    <left>
        <VBox minWidth="260" prefWidth="260" maxWidth="260" spacing="0" styleClass="sidebar-root">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 24 22 18 22;">
                <ImageView fitWidth="36" fitHeight="36" preserveRatio="true" smooth="true">
                    <image><Image url="@/images/taskforge-icon-48.png"/></image>
                </ImageView>
                <VBox spacing="0">
                    <HBox spacing="0" alignment="CENTER_LEFT">
                        <Label text="Task" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Forge" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #818CF8;"/>
                    </HBox>
                    <Label text="Project Hub Mahasiswa" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                </VBox>
            </HBox>

            <VBox spacing="10" styleClass="sidebar-profile-card">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane prefWidth="44" prefHeight="44">
                        <Rectangle width="44" height="44" arcWidth="44" arcHeight="44" style="-fx-fill: #4F46E5;"/>
                        <Label fx:id="avatarInitials" text="?"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"
                               StackPane.alignment="CENTER"/>
                    </StackPane>
                    <VBox spacing="1">
                        <Label fx:id="userNameLabel"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #F1F5F9;"
                               maxWidth="150"/>
                        <Label fx:id="userNimLabel" text="" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="userRoleLabel" styleClass="role-pill"/>
                </HBox>
            </VBox>

            <Label text="WORKSPACE"
                   style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 18 0 8 22;"/>
            <VBox spacing="2" style="-fx-padding: 0 10 0 10;">
                <Button text="📊   Dashboard" onAction="#handleDashboard" styleClass="nav-item" style="-fx-max-width: Infinity;"/>
                <Button text="📁   Proyek" styleClass="nav-item-active" style="-fx-max-width: Infinity;"/>
                <Button text="🔔   Notifikasi" onAction="#handleNotifikasi" styleClass="nav-item" style="-fx-max-width: Infinity;"/>
                <Button text="👤   Profil" onAction="#handleProfil" styleClass="nav-item" style="-fx-max-width: Infinity;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox style="-fx-border-color: #1E293B; -fx-border-width: 1 0 0 0; -fx-padding: 8 10 14 10;">
                <Button text="🚪   Keluar" onAction="#handleLogout" styleClass="nav-item-logout" style="-fx-max-width: Infinity;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ==================== MAIN CONTENT ==================== -->
    <center>
        <VBox spacing="0" style="-fx-background-color: #F8FAFC;">

            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 16 28 14 28; -fx-background-color: white;
                         -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;
                         -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.04), 4, 0, 0, 2);">
                <VBox spacing="2">
                    <Label text="Proyek"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                    <Label text="Kelola semua proyek kelompok kamu di sini"
                           style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="newProjectButton" text="+ Buat Proyek Baru"
                        onAction="#handleNewProject"
                        style="-fx-background-color: #4F46E5; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 10; -fx-padding: 9 20 9 20;
                               -fx-cursor: hand;"/>
            </HBox>

            <!-- Tabs -->
            <HBox spacing="8" alignment="CENTER_LEFT"
                  style="-fx-padding: 16 28 0 28; -fx-background-color: #F8FAFC;">
                <Button fx:id="tabMineButton" text="Proyek Saya" onAction="#handleTabMine"
                        styleClass="proyek-tab-active"/>
                <Button fx:id="tabAvailableButton" text="Tersedia (0)" onAction="#handleTabAvailable"
                        styleClass="proyek-tab"/>
            </HBox>

            <ScrollPane fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox spacing="16" style="-fx-padding: 20 28 28 28;">

                    <ProgressIndicator fx:id="loadingIndicator"
                                       prefWidth="36" prefHeight="36" visible="false"/>
                    <Label fx:id="statusLabel"
                           style="-fx-text-fill: #EF4444; -fx-font-size: 13px;"/>

                    <FlowPane fx:id="projectsPane" hgap="20" vgap="20"/>

                    <VBox fx:id="emptyStatePane" alignment="CENTER" spacing="10"
                          visible="false" managed="false"
                          style="-fx-padding: 60 0 60 0;">
                        <Label fx:id="emptyTitleLabel" text="Belum ada proyek"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                        <Label fx:id="emptySubtitleLabel" text="Proyek kamu akan muncul di sini"
                               style="-fx-font-size: 13px; -fx-text-fill: #94A3B8;"/>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
