<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taskforge.ui.controller.KanbanController"
            style="-fx-background-color: #F8FAFC;">

    <!-- ==================== HEADER ==================== -->
    <top>
        <VBox style="-fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 8, 0, 0, 3);">

            <!-- Top bar -->
            <HBox alignment="CENTER_LEFT" spacing="14"
                  style="-fx-background-color: #0F172A; -fx-padding: 12 24 12 20;">
                <Button text="← Dashboard" onAction="#handleBack"
                        style="-fx-background-color: transparent; -fx-text-fill: #94A3B8;
                               -fx-font-size: 12px; -fx-cursor: hand;
                               -fx-border-color: #334155; -fx-border-radius: 6;
                               -fx-background-radius: 6; -fx-padding: 5 12 5 12;"/>
                <Label fx:id="projectTitleLabel"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;
                              -fx-max-width: 500;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusLabel"
                       style="-fx-text-fill: #FCA5A5; -fx-font-size: 12px;"/>
                <Button fx:id="addTaskButton" text="+ Tambah Task"
                        onAction="#handleAddTask"
                        style="-fx-background-color: #4F46E5; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 7 16 7 16;
                               -fx-cursor: hand;"/>
            </HBox>

            <!-- Tab bar: white with underline on active tab -->
            <HBox alignment="CENTER_LEFT" spacing="0"
                  style="-fx-background-color: white;
                         -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;
                         -fx-padding: 0 24 0 24;">
                <Button text="Kanban"
                        style="-fx-background-color: transparent; -fx-text-fill: #4F46E5;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 11 18 11 18; -fx-background-radius: 0; -fx-cursor: hand;
                               -fx-border-color: transparent transparent #4F46E5 transparent;
                               -fx-border-width: 0 0 2 0;"/>
                <Button text="File Hub" onAction="#handleFileHub"
                        style="-fx-background-color: transparent; -fx-text-fill: #64748B;
                               -fx-font-size: 13px; -fx-padding: 11 18 11 18;
                               -fx-background-radius: 0; -fx-cursor: hand;"/>
                <Button text="Laporan &amp; Skor" onAction="#handleReport"
                        style="-fx-background-color: transparent; -fx-text-fill: #64748B;
                               -fx-font-size: 13px; -fx-padding: 11 18 11 18;
                               -fx-background-radius: 0; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ==================== KANBAN BOARD ==================== -->
    <!-- NOTE: KanbanController.trimColumn() keeps child[0] (header HBox),
         removes child[1..n] on refresh, then addTaskCards() appends to the VBox -->
    <center>
        <ScrollPane fitToHeight="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <HBox spacing="16" style="-fx-padding: 20 24 24 24;">

                <!-- TO-DO -->
                <VBox fx:id="todoColumn" spacing="10"
                      style="-fx-background-color: #F1F5F9; -fx-background-radius: 14;
                             -fx-padding: 0 10 14 10; -fx-min-width: 260; -fx-pref-width: 272;">
                    <!-- Header: index 0 — kept by trimColumn -->
                    <HBox alignment="CENTER_LEFT" spacing="8"
                          style="-fx-padding: 12 0 10 0;
                                 -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
                        <Label text="●" style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;"/>
                        <Label text="TO-DO"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                    </HBox>
                    <!-- Task cards appended here by controller -->
                </VBox>

                <!-- IN PROGRESS -->
                <VBox fx:id="inProgressColumn" spacing="10"
                      style="-fx-background-color: #EEF2FF; -fx-background-radius: 14;
                             -fx-padding: 0 10 14 10; -fx-min-width: 260; -fx-pref-width: 272;">
                    <HBox alignment="CENTER_LEFT" spacing="8"
                          style="-fx-padding: 12 0 10 0;
                                 -fx-border-color: #C7D2FE; -fx-border-width: 0 0 1 0;">
                        <Label text="●" style="-fx-text-fill: #4F46E5; -fx-font-size: 10px;"/>
                        <Label text="IN PROGRESS"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                    </HBox>
                </VBox>

                <!-- REVIEW -->
                <VBox fx:id="reviewColumn" spacing="10"
                      style="-fx-background-color: #FFFBEB; -fx-background-radius: 14;
                             -fx-padding: 0 10 14 10; -fx-min-width: 260; -fx-pref-width: 272;">
                    <HBox alignment="CENTER_LEFT" spacing="8"
                          style="-fx-padding: 12 0 10 0;
                                 -fx-border-color: #FDE68A; -fx-border-width: 0 0 1 0;">
                        <Label text="●" style="-fx-text-fill: #F59E0B; -fx-font-size: 10px;"/>
                        <Label text="REVIEW"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #D97706;"/>
                    </HBox>
                </VBox>

                <!-- DONE -->
                <VBox fx:id="doneColumn" spacing="10"
                      style="-fx-background-color: #F0FDF4; -fx-background-radius: 14;
                             -fx-padding: 0 10 14 10; -fx-min-width: 260; -fx-pref-width: 272;">
                    <HBox alignment="CENTER_LEFT" spacing="8"
                          style="-fx-padding: 12 0 10 0;
                                 -fx-border-color: #A7F3D0; -fx-border-width: 0 0 1 0;">
                        <Label text="●" style="-fx-text-fill: #10B981; -fx-font-size: 10px;"/>
                        <Label text="DONE"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                    </HBox>
                </VBox>

            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
