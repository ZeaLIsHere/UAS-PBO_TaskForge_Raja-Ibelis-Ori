<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.taskforge.ui.controller.RegisterController"
           prefWidth="480" prefHeight="620"
           style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #EEF2FF, #F1F5F9);">

    <VBox alignment="CENTER" spacing="0" maxWidth="400">

        <!-- Card -->
        <VBox styleClass="form-card" spacing="14">
            <padding>
                <Insets top="28" right="32" bottom="28" left="32"/>
            </padding>

            <VBox spacing="3">
                <Label text="Daftar Akun Baru"
                       style="-fx-font-size: 19px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                <Label text="Isi data di bawah untuk membuat akun"
                       style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Nama Lengkap" styleClass="field-label"/>
                <TextField fx:id="nameField"
                           promptText="Masukkan nama lengkap"
                           styleClass="text-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Alamat Email" styleClass="field-label"/>
                <TextField fx:id="emailField"
                           promptText="nama@email.com"
                           styleClass="text-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="Minimal 8 karakter"
                               styleClass="text-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Konfirmasi Password" styleClass="field-label"/>
                <PasswordField fx:id="confirmPasswordField"
                               promptText="Ulangi password"
                               styleClass="text-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Role" styleClass="field-label"/>
                <ComboBox fx:id="roleBox" maxWidth="Infinity"
                          style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0;
                                 -fx-border-radius: 8; -fx-background-radius: 8;"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label"
                   wrapText="true" visible="false"/>

            <VBox spacing="10" alignment="CENTER" style="-fx-padding: 4 0 0 0;">
                <Button fx:id="registerButton"
                        text="Buat Akun"
                        onAction="#handleRegister"
                        styleClass="primary-button"
                        maxWidth="Infinity"/>
                <ProgressIndicator fx:id="loadingIndicator"
                                   prefWidth="28" prefHeight="28"
                                   visible="false"/>
            </VBox>

            <HBox alignment="CENTER" spacing="4">
                <Label text="Sudah punya akun?"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
                <Hyperlink text="Masuk di sini"
                           onAction="#handleBackToLogin"
                           style="-fx-text-fill: #4F46E5; -fx-font-size: 13px;
                                  -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
